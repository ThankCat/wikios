DEEPSEEK_API_KEY=your-deepseek-api-key
WIKIOS_CONFIG=configs/config.local.yaml
WIKIOS_RETRIEVAL_MODE=qmd
WIKIOS_QMD_INDEX=knowledge-base
WIKIOS_QMD_AUTO_COLLECTION=true
WIKIOS_QMD_HTTP_ENABLED=true
WIKIOS_QMD_QUERY_MODE=query
WIKIOS_LLM_TIMEOUT_SEC=300
WIKIOS_LLM_ADMIN_TIMEOUT_SEC=300
WIKIOS_CUSTOMER_CANDIDATE_TOP_K=6
WIKIOS_CUSTOMER_MAX_EVIDENCE_CHARS=2400
WIKIOS_CUSTOMER_RESPONSE_TIMEOUT_SEC=300
WIKIOS_CUSTOMER_MAX_CONCURRENT=1
WIKIOS_CUSTOMER_CHAT_LOG_ENABLED=true
WIKIOS_CUSTOMER_CHAT_LOG_REDACT=true
WIKIOS_CUSTOMER_CHAT_LOG_RETENTION_DAYS=14
WIKIOS_CONTEXT_MAX_TOKENS=1000000
WIKIOS_CONTEXT_RESERVE_TOKENS=8192
WIKIOS_CONTEXT_COUNTER=tokenizer
WIKIOS_CONTEXT_TOKENIZER=cl100k_base
WIKIOS_WIKI_GIT_URL=
WIKIOS_WIKI_GIT_TOKEN=
WIKIOS_WIKI_GIT_USERNAME=x-access-token
WIKIOS_WIKI_GIT_BRANCH=main
WIKIOS_WIKI_GIT_REMOTE=origin
WIKIOS_WIKI_GIT_PULL_ON_START=true
WIKIOS_WIKI_GIT_RESET_ON_START=false
